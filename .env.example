# MongoDB (certificate-based authentication)
MONGODB_URI=mongodb+srv://<cluster>.mongodb.net/?authSource=%24external&authMechanism=MONGODB-X509&retryWrites=true&w=majority
MONGODB_DB_NAME=barta_ai
MONGODB_TLS_CERT_KEY_FILE=/path/to/your-certificate.pem

# OpenAI (required if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# LLM Provider: "openai", "anthropic", "google", "groq", or "ollama"
# openai     → GPT-4o, GPT-4o-mini, GPT-4.1, GPT-4.1-mini, GPT-4.1-nano
# anthropic  → Claude 3.5 Sonnet, Claude 3.5 Haiku
# google     → Gemini 2.0 Flash, Gemini 2.5 Pro
# groq       → Llama 3.3 70B, Mixtral (fast & cheap)
# ollama     → Local models (Llama 3, Mistral, etc.)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Anthropic (required only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google (required only if LLM_PROVIDER=google)
GOOGLE_API_KEY=

# Groq (required only if LLM_PROVIDER=groq)
GROQ_API_KEY=

# Ollama (required only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Common LLM model choices:
#   openai:     gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano
#   anthropic:  claude-sonnet-4-20250514, claude-3-5-haiku-20241022
#   google:     gemini-2.0-flash, gemini-2.5-pro
#   groq:       llama-3.3-70b-versatile, mixtral-8x7b-32768
#   ollama:     llama3, mistral, gemma, phi3 (any model pulled locally)

# Embedding Provider: "openai", "cohere", or "local"
# openai  → uses OpenAI text-embedding-3-small/large (API, good multilingual)
# cohere  → uses Cohere embed-multilingual-v3.0 (API, excellent Bangla)
# local   → uses sentence-transformers models locally (free, no API key)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Cohere (required only if EMBEDDING_PROVIDER=cohere)
COHERE_API_KEY=

# Common embedding model choices:
#   openai:  text-embedding-3-small (1536d), text-embedding-3-large (3072d)
#   cohere:  embed-multilingual-v3.0 (1024d), embed-multilingual-light-v3.0 (384d)
#   local:   intfloat/multilingual-e5-large (1024d),
#            sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (384d)

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Vector Search
VECTOR_SEARCH_INDEX_NAME=news_vector_index
VECTOR_SEARCH_NUM_CANDIDATES=100
VECTOR_SEARCH_LIMIT=10

# CORS (comma-separated values)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type

# Rate Limiting
RATE_LIMIT=20/minute
RATE_LIMIT_ENABLED=true

# App
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

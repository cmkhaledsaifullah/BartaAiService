# MongoDB (mocked in integration tests — no real connection needed)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=bartaAi
MONGODB_TLS_CERT_KEY_FILE=

# LLM (mocked in integration tests — no real API calls)
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Embedding (mocked in integration tests — no real API calls)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# JWT (real signing used in auth tests)
JWT_SECRET_KEY=e2e-test-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting (disabled for tests)
RATE_LIMIT=100/minute
RATE_LIMIT_ENABLED=false

# App
APP_ENV=test
APP_DEBUG=false
LOG_LEVEL=WARNING
